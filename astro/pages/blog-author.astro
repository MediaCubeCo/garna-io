---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import { pageShells } from '../content/page-shells';
import rawContentHtml from '../content/site-pages/blog-author.html?raw';

const authorContentHtml = rawContentHtml.replace(
	/<!-- Hero Section -->[\s\S]*?<\/section>\s*(?=\s*<!-- AI Matching Feature -->)/,
	''
);

const authorHero = {
	class: 'flex flex-col md:pt-32 md:pb-0 w-full pt-24 pb-8 relative justify-center',
	containerClass:
		'flex flex-col md:pl-6 md:pr-6 md:pt-0 w-full max-w-7xl z-10 mr-auto ml-auto pt-0 pr-6 pl-6 relative items-center',
	contentClass: 'flex flex-col text-center z-10 relative items-center w-full max-w-4xl mr-auto ml-auto',
	titleClass: 'leading-tight text-4xl md:text-5xl text-white tracking-tight font-manrope mb-6',
	descriptionClass: 'leading-relaxed text-lg font-light text-gray-400 font-manrope pb-12 max-w-3xl mx-auto',
	title: [
		{
			text: 'Dr. Emily Chen',
			translateKey: 'blogAuthor.hero.name',
		},
	],
	description:
		'Exploring architectural patterns and frontend strategies to build scalable, high-performance web tools for genomic data analysis and research collaboration. Passionate about bridging the gap between life sciences and software engineering',
	descriptionTranslateKey: 'blogAuthor.hero.bio',
	tone: 'neutral',
};
---

<BaseLayout shell={pageShells.blogAuthor}>
	<HeroSection {...authorHero}>
		<div slot="before-title" class="contents">
			<div class="mb-8 relative">
				<div class="w-32 h-32 rounded-full border border-[#5ea500]/30 p-1.5 flex items-center justify-center bg-[#5ea500]/5 shadow-[0_0_30px_-5px_rgba(94,165,0,0.3)]">
					<img src="/pages/blog/assets/12-photo-1438761681033-6461ffad8d80.jpg" alt="Dr. Emily Chen" class="w-full h-full rounded-full object-cover" data-translate-alt="blogAuthor.hero.avatarAlt">
				</div>
			</div>

			<div class="flex flex-wrap items-center justify-center gap-3 mb-6">
				<span class="text-[#5ea500] text-xs font-light uppercase tracking-wider bg-[#5ea500]/10 px-4 py-1.5 rounded-full border border-[#5ea500]/20" data-translate="blogAuthor.hero.kicker">Author Profile</span>
				<span class="w-1 h-1 rounded-full bg-gray-600 hidden sm:block"></span>
				<span class="text-gray-400 text-sm font-extralight" data-translate="blogAuthor.hero.role">Lead Software Architect</span>
			</div>
		</div>

		<div class="flex flex-col sm:flex-row sm:gap-12 w-full border-white/10 border-t pt-8 gap-x-8 gap-y-8 items-center justify-center">
			<div class="flex items-center gap-4">
				<a href="#" aria-label="X Profile" class="w-11 h-11 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-[#5ea500] hover:border-[#5ea500] transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
						<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L5.09 21.75H1.78l7.509-8.58L1.141 2.25H7.96l4.694 6.233zm-1.16 17.52h1.833L7.084 4.126H5.117z"></path>
					</svg>
				</a>
				<a href="#" aria-label="LinkedIn Profile" class="w-11 h-11 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-[#5ea500] hover:border-[#5ea500] transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin">
						<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
						<rect width="4" height="12" x="2" y="9"></rect>
						<circle cx="4" cy="4" r="2"></circle>
					</svg>
				</a>
				<a href="mailto:#" aria-label="Email" class="w-11 h-11 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-[#5ea500] hover:border-[#5ea500] transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail">
						<rect width="20" height="16" x="2" y="4" rx="2"></rect>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
					</svg>
				</a>
			</div>
		</div>
	</HeroSection>
	<Fragment set:html={authorContentHtml} />
</BaseLayout>
