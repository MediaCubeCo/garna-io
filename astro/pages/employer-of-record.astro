---
import HeroSection from '../components/HeroSection.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTASection from '../components/FinalCTASection.astro';
import GarnaBookingWidget from '../components/GarnaBookingWidget.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageFinalCtas } from '../content/page-final-ctas';
import { pageHeroes } from '../content/page-heroes';
import { pageShells } from '../content/page-shells';
import type { FAQItem } from '../types/faq-section';
import rawContentHtml from '../content/site-pages/eor.html?raw';
import scriptsHtml from '../content/site-scripts/eor.html?raw';
import { splitLegacyPageSections } from '../utils/legacy-html';

const { heroVisualHtml, contentHtml } = splitLegacyPageSections(rawContentHtml, {
	heroVisualMarker: '<!-- Dashboard Mockup with Dynamic Sizing -->',
});

const eorFaqItems = [
	{
		question: 'What is an Employer of Record (EoR)?',
		answer:
			"An Employer of Record (EoR) is a third-party company that legally employs workers on behalf of another business. They're the ones responsible for handling things, like payroll, taxes, compliance, contracts, and making sure the local employment rules are followed",
		questionTranslateKey: 'faq.items.q1.question',
		answerTranslateKey: 'faq.items.q1.answer',
	},
	{
		question: 'How is an EoR different from a professional employer organization (PEO)?',
		answer:
			"A PEO is a type of company that uses the 'co-employment' model. They work together with the client company to manage the employees. They usually need the client company to already have a local setup. An EoR, on the other hand, acts as the official employer so you don't need to set up a business in every country you want to work in",
		questionTranslateKey: 'faq.items.q2.question',
		answerTranslateKey: 'faq.items.q2.answer',
	},
	{
		question: 'When should you use an EoR?',
		answer:
			"If you want to start hiring people in countries you aren't already set up to do business in, an EoR is your solution. It lets you expand internationally without having to go through a tiring process of starting a subsidiary in each place and sorting out all the local labour rules",
		questionTranslateKey: 'faq.items.q3.question',
		answerTranslateKey: 'faq.items.q3.answer',
	},
	{
		question: 'EoR vs own international entity setup: which is better?',
		answer:
			"Setting up a local entity can be expensive and tiring, especially if you're just starting out in a new market. An EoR is usually faster to set up and way more flexible for businesses that need to hire globally. You can try out new regions, scale your team without any complexities",
		questionTranslateKey: 'faq.items.q4.question',
		answerTranslateKey: 'faq.items.q4.answer',
	},
	{
		question: 'What EoR model does Garna have?',
		answer: 'Garna has a flexible global EoR solution that includes all the necessary features you need, like payroll, compliance, and onboarding in a single platform. We also have API integrations and white-label options as well as support for teams that work across multiple countries',
		questionTranslateKey: 'faq.items.q5.question',
		answerTranslateKey: 'faq.items.q5.answer',
	},
] satisfies FAQItem[];
---

<BaseLayout shell={pageShells.eor} scriptsHtml={scriptsHtml}>
	<HeroSection {...pageHeroes.eor}>
		<Fragment set:html={heroVisualHtml} />
	</HeroSection>
	<Fragment set:html={contentHtml} />
	<FAQSection
		kicker={{ text: 'FAQ', translateKey: 'faq.kicker' }}
		title={{ text: 'FAQ on Employer of Record', translateKey: 'faq.title' }}
		items={eorFaqItems}
		variant="eor"
		class="py-24"
		containerClass="garna-container"
	/>
	<FinalCTASection {...pageFinalCtas.eor} />
	<Fragment slot="widgets">
		<GarnaBookingWidget
			trackingSource="eor"
			trackingPage="eor"
			titleFallback="Book a free 30-minute product demo"
			subtitleFallback="Get all your questions answered by our experts"
		/>
	</Fragment>
</BaseLayout>
