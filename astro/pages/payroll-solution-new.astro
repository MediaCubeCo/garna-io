---
import HeroSection from '../components/HeroSection.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTASection from '../components/FinalCTASection.astro';
import GarnaBookingWidget from '../components/GarnaBookingWidget.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageFinalCtas } from '../content/page-final-ctas';
import { pageHeroes } from '../content/page-heroes';
import { pageShells } from '../content/page-shells';
import type { FAQItem } from '../types/faq-section';
import rawContentHtml from '../content/site-pages/payroll-solution-new.html?raw';
import { splitLegacyPageSections } from '../utils/legacy-html';

const { contentHtml } = splitLegacyPageSections(rawContentHtml);
const faqSectionMarker = '<section class="border-white/5 border-t pt-16 pr-6 pb-16 pl-6 lg:pt-32 lg:pb-32">';
const faqSectionIndex = contentHtml.indexOf(faqSectionMarker);
const legacyContentHtml = faqSectionIndex >= 0 ? contentHtml.slice(0, faqSectionIndex) : contentHtml;

const payrollSolutionNewFaqItems = [
	{
		question: 'How quickly can I start using Garna Payroll?',
		answer:
			'Average time from sign up to the first hire or contractor payment is less than 10 minutes. You can create an account, verify it, and start using it immediately after. Our team processes applications quickly and grants access to one of the best online payroll services and contractor management solutions. At this point we work as a payroll provider enabling you with the possibility to work with employees and contractors.',
		questionTranslateKey: 'faq.items.q1.question',
		answerTranslateKey: 'faq.items.q1.answer',
	},
	{
		question: 'Can I brand the contractor dashboard under my company?',
		answer:
			'Of course! Our White Label solution allows you to fully customize the interface not only for your in-house contractors but also for your customers.',
		questionTranslateKey: 'faq.items.q2.question',
		answerTranslateKey: 'faq.items.q2.answer',
	},
	{
		question: 'What payment methods does Garna support?',
		answer:
			'We support bank transfers (SWIFT, SEPA, bank transfers in local currencies), payments to cards in local currency, PayPal, Payoneer, and payments in cryptocurrency (USDT/USDC).',
		questionTranslateKey: 'faq.items.q3.question',
		answerTranslateKey: 'faq.items.q3.answer',
	},
	{
		question: 'How does Garna handle taxes and compliance globally?',
		answer:
			"You won't have to worry about red tape. When working with our Employment of Record solution, we handle all local taxes, social contributions, insurance, and compliance. When working with our Contractor of Record solution, Garna ensures to avoid risk of worker misclassification. As your contractor of record agent, we take full responsibility for hiring so that you can focus on the growth of your company.",
		questionTranslateKey: 'faq.items.q4.question',
		answerTranslateKey: 'faq.items.q4.answer',
	},
	{
		question: 'Can I integrate the Garna API into my platform?',
		answer: 'Yes. With our API, you can automate payments to contractors within your product.',
		questionTranslateKey: 'faq.items.q5.question',
		answerTranslateKey: 'faq.items.q5.answer',
	},
	{
		question: 'What currencies are supported for payouts?',
		answer:
			'We support 80+ local currencies, including USD, EUR, and GBP. At Garna, we believe that businesses should have best exchange rates without markups.',
		questionTranslateKey: 'faq.items.q6.question',
		answerTranslateKey: 'faq.items.q6.answer',
	},
	{
		question: 'How does Garna handle contractor management?',
		answer:
			'Garna automates the entire process, from onboarding and compliance checks to instant invoice generation. You pay a single consolidated invoice, and we distribute the funds to contractors in their preferred payment method and currency. Garna takes the risk of misclassification and handles local compliance.',
		questionTranslateKey: 'faq.items.q7.question',
		answerTranslateKey: 'faq.items.q7.answer',
	},
	{
		question: 'Is my data secure with Garna?',
		answer:
			'Of course. As top global payroll providers, Garna uses bank-level encryption and strictly adheres to GDPR protocols and financial data security standards. Plus, only you have access to your personal account. You can delete your personal account at any time.',
		questionTranslateKey: 'faq.items.q8.question',
		answerTranslateKey: 'faq.items.q8.answer',
	},
	{
		question: 'Can I use Garna Payroll if my business already has its own dashboard?',
		answer: 'Yes, we can integrate any of our tools into your workflows.',
		questionTranslateKey: 'faq.items.q9.question',
		answerTranslateKey: 'faq.items.q9.answer',
	},
	{
		question: 'Do you offer support for global payroll issues?',
		answer:
			'Yes, of course. Our support team is always on call 24/7 to answer any questions you may have about the service, payments, etc.',
		questionTranslateKey: 'faq.items.q10.question',
		answerTranslateKey: 'faq.items.q10.answer',
	},
] satisfies FAQItem[];
---

<BaseLayout shell={pageShells.payrollSolutionNew}>
	<HeroSection {...pageHeroes.payrollSolutionNew} />
	<Fragment set:html={legacyContentHtml} />
	<FAQSection
		title={{ text: 'FAQ on Payroll Solutions', translateKey: 'faq.title' }}
		items={payrollSolutionNewFaqItems}
		class="pt-16 pr-6 pb-16 pl-6 lg:pt-32 lg:pb-32"
		containerClass="max-w-3xl mr-auto ml-auto"
	/>
	<FinalCTASection {...pageFinalCtas.payrollSolutionNew} />
	<script is:inline>
		document.addEventListener('click', (event) => {
			const link = event.target instanceof Element ? event.target.closest('a') : null;
			if (!link || link.getAttribute('href') !== '#') return;
			if (!link.textContent || !link.textContent.toLowerCase().includes('book a demo')) return;

			event.preventDefault();
			if (window.GarnaWidget) {
				window.GarnaWidget.open({ trackingCta: 'payroll_solution_new_demo' });
			}
		});
	</script>
	<Fragment slot="widgets">
		<GarnaBookingWidget
			trackingSource="payroll-solution-new"
			trackingPage="payroll-solution-new"
			titleFallback="Start your journey with Garna"
			subtitleFallback="Fill in your details to book a demo"
		/>
	</Fragment>
</BaseLayout>

<style is:global>
	html[lang='ru'] .payroll-solution-new-hero h1,
	html[lang='es'] .payroll-solution-new-hero h1 {
		font-size: 2.75rem;
		line-height: 1.08;
	}

	@media (min-width: 768px) {
		html[lang='ru'] .payroll-solution-new-hero h1,
		html[lang='es'] .payroll-solution-new-hero h1 {
			font-size: 3rem;
		}
	}

	@media (min-width: 1024px) {
		html[lang='ru'] .payroll-solution-new-hero h1,
		html[lang='es'] .payroll-solution-new-hero h1 {
			font-size: 3.5rem;
			line-height: 1.06;
		}

		html[lang='ru'] .payroll-deferred-section .payroll-deferred-grid {
			grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.82fr);
		}

		html[lang='ru'] .payroll-deferred-section .payroll-deferred-copy {
			overflow-wrap: normal !important;
			word-break: normal !important;
		}

		html[lang='ru'] .payroll-deferred-section .payroll-deferred-copy h2 {
			font-size: 2.75rem;
			line-height: 1.08;
			max-width: 42rem;
		}
	}
</style>
