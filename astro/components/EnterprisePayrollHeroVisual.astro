<style>
	.enterprise-payroll-progress-bar {
		transform-origin: left center;
		animation: enterprise-payroll-progress-load 1.8s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.enterprise-payroll-sync-dot {
		box-shadow: 0 0 8px rgba(94, 165, 0, 0.72);
		animation: enterprise-payroll-sync-pulse 1.6s ease-in-out infinite;
	}

	@keyframes enterprise-payroll-progress-load {
		from {
			transform: scaleX(0);
		}

		to {
			transform: scaleX(1);
		}
	}

	@keyframes enterprise-payroll-sync-pulse {
		0%,
		100% {
			opacity: 0.62;
			transform: scale(0.86);
			box-shadow: 0 0 6px rgba(94, 165, 0, 0.5);
		}

		50% {
			opacity: 1;
			transform: scale(1.08);
			box-shadow: 0 0 14px rgba(94, 165, 0, 0.86);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.enterprise-payroll-progress-bar,
		.enterprise-payroll-sync-dot {
			animation: none;
		}
	}
</style>

<script is:inline>
	(function () {
		const el = document.querySelector('.enterprise-payroll-count-up');
		if (!el) return;

		const target = 1840000;
		const duration = 2000;
		const format = (value) => Math.floor(value).toLocaleString('en-US');

		function run() {
			let start = null;
			function step(timestamp) {
				if (!start) start = timestamp;
				const progress = Math.min((timestamp - start) / duration, 1);
				const ease = 1 - Math.pow(1 - progress, 4);
				el.textContent = format(target * ease);
				if (progress < 1) {
					window.requestAnimationFrame(step);
				} else {
					el.textContent = format(target);
					setTimeout(() => window.requestAnimationFrame(run), 2200);
				}
			}
			window.requestAnimationFrame(step);
		}

		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver(
				(entries) => {
					if (entries.some((entry) => entry.isIntersecting)) {
						run();
						observer.disconnect();
					}
				},
				{ threshold: 0.1 }
			);
			observer.observe(el);
		} else {
			run();
		}
	})();
</script>
