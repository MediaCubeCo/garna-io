const extractEorWhyGarnaSection = () => {
	const start = eorContentHtml.indexOf('<section id="why-garna"');
	if (start === -1) return '';

	const end = eorContentHtml.indexOf('\n        <section', start + 1);
	const sectionHtml = eorContentHtml.slice(start, end === -1 ? undefined : end);

	return eorWhyGarnaStylesHtml + translateSimpleDataText(sectionHtml, isEnterprisePayroll ? enterprisePayrollEorWhyGarnaTranslations : eorEn);
};

const eorWhyGarnaSectionHtml = isEnterprisePayroll ? eorWhyGarnaStylesHtml + enterprisePayrollWhyGarnaSectionHtml : extractEorWhyGarnaSection();

