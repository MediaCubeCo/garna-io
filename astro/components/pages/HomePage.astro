---
import FAQSection from '../FAQSection.astro';
import FinalCTASection from '../FinalCTASection.astro';
import GarnaBookingWidget from '../GarnaBookingWidget.astro';
import HeroSection from '../HeroSection.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pageFinalCtas } from '../../content/page-final-ctas';
import { pageHeroes } from '../../content/page-heroes';
import { pageShells } from '../../content/page-shells';
import type { FAQItem } from '../../types/faq-section';
import rawContentHtml from '../../content/site-pages/home.html?raw';
import scriptsHtml from '../../content/site-scripts/home.html?raw';
import { splitLegacyPageSections } from '../../utils/legacy-html';

const { heroVisualHtml, contentHtml } = splitLegacyPageSections(rawContentHtml, {
	heroVisualMarker: '<!-- Dashboard Mockup with Dynamic Sizing -->',
});

const homeFaqItems = [
	{
		question: 'How do I get started with Garna?',
		answer: 'Sign up on our platform, contact our sales team, and start processing payroll in just a few steps.',
		questionTranslateKey: 'faqHome.items.q1.question',
		answerTranslateKey: 'faqHome.items.q1.answer',
	},
	{
		question: 'What payment methods does Garna support?',
		answer: 'We offer bank transfers in USD, local currencies, e-wallets and crypto.',
		questionTranslateKey: 'faqHome.items.q2.question',
		answerTranslateKey: 'faqHome.items.q2.answer',
	},
	{
		question: 'Can I pay contractors in multiple countries?',
		answer: 'Yes, Garna supports payroll in over 150 countries worldwide.',
		questionTranslateKey: 'faqHome.items.q3.question',
		answerTranslateKey: 'faqHome.items.q3.answer',
	},
	{
		question: 'Are there any minimum payment limits?',
		answer: 'No, you can process payroll of any amount that fits your business needs.',
		questionTranslateKey: 'faqHome.items.q4.question',
		answerTranslateKey: 'faqHome.items.q4.answer',
	},
] satisfies FAQItem[];
---

<BaseLayout shell={pageShells.home} scriptsHtml={scriptsHtml}>
	<HeroSection {...pageHeroes.home}>
		<Fragment set:html={heroVisualHtml} />
	</HeroSection>
	<Fragment set:html={contentHtml} />
	<FAQSection
		title={{ text: 'Frequently asked questions', translateKey: 'faqHome.title' }}
		subtitle={{ text: "Got Questions? We've Got Answers", translateKey: 'faqHome.subtitle' }}
		items={homeFaqItems}
		class="pt-16 pb-16 lg:pt-32 lg:pb-32"
		containerClass="garna-container"
	/>
	<FinalCTASection {...pageFinalCtas.home} />
	<script is:inline>
		(function () {
			function formatValue(value, decimals) {
				return value.toLocaleString('en-US', {
					minimumFractionDigits: decimals,
					maximumFractionDigits: decimals,
				});
			}

			function initCounterAnimation() {
				const elements = document.querySelectorAll('.counter-anim');
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				elements.forEach((el) => {
					const target = parseFloat(el.getAttribute('data-target'));
					const prefix = el.getAttribute('data-prefix') || '';
					const suffix = el.getAttribute('data-suffix') || '';
					const decimals = parseInt(el.getAttribute('data-decimals') || 0);
					const finalValue = prefix + formatValue(target, decimals) + suffix;

					if (prefersReducedMotion) {
						el.innerText = finalValue;
						return;
					}

					function animate() {
						if (el.dataset.counterAnimated === 'true') return;
						el.dataset.counterAnimated = 'true';
						const start = 0;
						const duration = 2000;
						const startTime = performance.now();

						function update(currentTime) {
							const elapsed = currentTime - startTime;
							const progress = Math.min(elapsed / duration, 1);
							const ease = 1 - Math.pow(1 - progress, 4);
							const current = start + (target - start) * ease;

							el.innerText = prefix + formatValue(current, decimals) + suffix;

							if (progress < 1) {
								requestAnimationFrame(update);
							} else {
								el.innerText = finalValue;
							}
						}

						requestAnimationFrame(update);
					}

					if ('IntersectionObserver' in window) {
						const observer = new IntersectionObserver((entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									animate();
									observer.disconnect();
								}
							});
						}, { threshold: 0.1 });

						observer.observe(el);
					} else {
						animate();
					}
				});
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initCounterAnimation, { once: true });
			} else {
				initCounterAnimation();
			}
		})();
	</script>
	<Fragment slot="widgets">
		<GarnaBookingWidget
			trackingSource="payroll-solution"
			trackingPage="payroll-solution"
			titleFallback="Start your journey with Garna"
			subtitleFallback="Fill in your details to book a demo"
		/>
	</Fragment>
</BaseLayout>

<style is:global>
	.home-hero h1 {
		margin-left: auto;
		margin-right: auto;
		padding-bottom: 0.12em;
	}

	html[lang='en'] .home-hero h1 {
		max-width: 50rem;
	}

	html[lang='es'] .home-hero h1,
	html[lang='pt'] .home-hero h1 {
		max-width: 64rem;
		line-height: 1.14;
	}

	html[lang='es'] .home-hero h1 {
		max-width: 58rem;
	}

	@media (min-width: 1024px) {
		html[lang='pt'] .home-hero h1 {
			font-size: 4rem;
		}
	}
</style>
