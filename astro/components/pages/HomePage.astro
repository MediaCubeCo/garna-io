		(_match, suffix: string) => `${enterprisePayrollHowToCompositeVisualHtml}${suffix}`
	);

const removeEnterprisePayrollHowToBackground = (html: string) =>
	html.replace(
		'<section class="bg-[#020202] pt-16 pb-16 lg:pt-32 lg:pb-32" id="get-started">',
		'<section class="pt-16 pb-16 lg:pt-32 lg:pb-32" id="get-started">'
	);

const widenEnterprisePayrollHowToBeforeSplit = (html: string) =>
	html.replace(
		'<div class="grid lg:grid-cols-2 gap-x-16 gap-y-16 items-center">',
		'<div class="grid xl:grid-cols-2 gap-x-16 gap-y-16 items-center">'
	);

const moveEnterprisePayrollHowToAfterSolutions = (html: string) => {
	const howToMatch = html.match(
		/(\s*<!-- How to get started \(INTERACTIVE\) -->\s*<section[\s\S]*?<\/section>)(\s*<!-- Contractor Payouts -->)/
	);

	if (!howToMatch) return html;

	const howToSection = howToMatch[1];
	const withoutHowTo = html.replace(howToMatch[0], howToMatch[2]);
	const solutionsTitleIndex = withoutHowTo.indexOf('data-translate="solutions.title"');

	if (solutionsTitleIndex === -1) return html;

	const solutionsEndIndex = withoutHowTo.indexOf('</section>', solutionsTitleIndex);

	if (solutionsEndIndex === -1) return html;

	const insertIndex = solutionsEndIndex + '</section>'.length;

	return `${withoutHowTo.slice(0, insertIndex)}\n\n${howToSection}${withoutHowTo.slice(insertIndex)}`;
};

const insertEnterprisePayrollComplexOperationsAfterHowTo = (html: string) =>
	html.replace(
		/(\s*<!-- How to get started \(INTERACTIVE\) -->\s*<section[\s\S]*?<\/section>)(\s*<!-- Why Garna -->)/,
		(_match, howToSection: string, whyGarnaMarker: string) =>
			`${howToSection}\n\n${enterprisePayrollComplexOperationsSectionHtml}\n\n${whyGarnaMarker}`
	);

const insertEnterprisePayrollTestimonialsAfterWhyGarna = (html: string) => {
	if (!enterprisePayrollTestimonialsSectionHtml) return html;

	return html.replace(
		/(^\s*<!-- Why Garna -->[\s\S]*?<\/section>)(\s*<!-- Contractor Payouts -->)/m,
		(_match, whyGarnaSection: string, contractorMarker: string) =>
			`${whyGarnaSection}\n\n${enterprisePayrollTestimonialsSectionHtml}${contractorMarker}`
	);
};

