type TranslationNode = string | { [key: string]: TranslationNode };

const getTranslationValue = (source: TranslationNode, path: string): string | undefined => {
	const value = path.split('.').reduce<TranslationNode | undefined>((current, segment) => {
		if (!current || typeof current === 'string') return undefined;
		return current[segment];
	}, source);

	return typeof value === 'string' ? value : undefined;
};

const translateSimpleDataText = (html: string, source: TranslationNode) =>
	html.replace(
		/(<([a-z][\w:-]*)(?=[^>]*\sdata-translate="([^"]+)")[^>]*>)([\s\S]*?)(<\/\2>)/g,
		(match, openTag: string, _tagName: string, key: string, _text: string, closeTag: string) => {
			const value = getTranslationValue(source, key);
			return value ? `${openTag}${value}${closeTag}` : match;
		}
	);

