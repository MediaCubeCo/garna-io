---
import '../styles/header.css';
import Button from './Button.astro';
import { getPagePathFromPathname } from '../utils/page-path';

const currentPath = getPagePathFromPathname(Astro.url.pathname);

const base = '/en';
const homeHref = base;
const offerHref = `${base}/for-contractors`;
const aiHiringHref = `${base}/ai-hiring`;
const whiteLabelPath = 'white-label-payroll';
const whiteLabelHref = `${base}/${whiteLabelPath}`;
const contractorOfRecordPath = 'contractor-of-record';
const contractorOfRecordHref = `${base}/${contractorOfRecordPath}`;
const employerOfRecordPath = 'employer-of-record';
const eorHref = `${base}/${employerOfRecordPath}`;
const smallBusinessPath = 'small-business-payroll';
const smallBusinessHref = `${base}/${smallBusinessPath}`;
const midSizePath = 'mid-size-business-payroll';
const midSizeHref = `${base}/${midSizePath}`;
const enterprisePayrollPath = 'enterprise-payroll';
const enterprisePayrollHref = `${base}/${enterprisePayrollPath}`;
const blogHref = `${base}/blog`;

const signUpUrl = 'https://app.garna.io/en/auth/sign-up';
const logInUrl = 'https://app.garna.io/en/auth/sign-in';

const navLinkClass = (path: string) =>
	[
		'garna-header-nav-link',
		currentPath === path ? 'is-active' : '',
	].join(' ');

const mobileLinkClass = (path: string) =>
	[
		'garna-header-mobile-link',
	].join(' ');
---

<nav class="garna-header fixed z-50 w-full top-0">
	<div class="garna-container garna-header-container">
		<a href={homeHref} data-garna-home data-localized-path="" class="garna-header-brand">
			<img
				src="/garna_logo.svg"
				alt="Garna"
				class="garna-header-logo"
				data-translate-alt="header.brand"
			/>
		</a>

		<div class="garna-header-desktop-nav" aria-label="Primary navigation">
			<div class="garna-header-menu-group">
				<button type="button" class="garna-header-menu-trigger">
					<span data-translate="header.products">Products</span>
					<svg class="garna-header-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="m6 9 6 6 6-6"></path>
					</svg>
				</button>

				<div class="garna-header-dropdown garna-header-products-dropdown">
					<div class="garna-header-dropdown-panel">
						<div class="garna-header-dropdown-column garna-header-products-column">
							<a href={homeHref} data-localized-path="" data-nav-link class="garna-header-dropdown-link">
								<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<circle cx="12" cy="12" r="10"></circle>
									<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
									<path d="M2 12h20"></path>
								</svg>
								<span class="garna-header-link-main" data-translate="header.globalPayroll">Global Payroll</span>
								<span class="garna-header-link-separator">|</span>
								<span class="garna-header-link-kicker" data-translate="header.globalPayrollKicker">Pay teams worldwide</span>
							</a>
							<a href={eorHref} data-localized-path={employerOfRecordPath} data-nav-link class="garna-header-dropdown-link">
								<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
									<circle cx="9" cy="7" r="4"></circle>
									<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
									<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
								</svg>
									<span class="garna-header-link-main" data-translate="header.eor">Employer of Record</span>
								<span class="garna-header-link-separator">|</span>
								<span class="garna-header-link-kicker" data-translate="header.eorKicker">Hire without local entity</span>
							</a>
							<a href={contractorOfRecordHref} data-localized-path={contractorOfRecordPath} data-nav-link class="garna-header-dropdown-link">
								<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
									<path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
								</svg>
								<span class="garna-header-link-main" data-translate="header.contractorOfRecord">Contractor of Record</span>
								<span class="garna-header-link-separator">|</span>
								<span class="garna-header-link-kicker" data-translate="header.contractorOfRecordKicker">Manage global contractors</span>
							</a>
						</div>
					</div>
				</div>
			</div>

			<div class="garna-header-menu-group">
				<button type="button" class="garna-header-menu-trigger">
					<span data-translate="header.solutions">Solutions</span>
					<svg class="garna-header-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="m6 9 6 6 6-6"></path>
					</svg>
				</button>

				<div class="garna-header-dropdown garna-header-solutions-dropdown">
					<div class="garna-header-dropdown-panel garna-header-solutions-panel">
						<div class="garna-header-solutions-columns">
							<div class="garna-header-dropdown-column">
								<h3 class="garna-header-dropdown-title" data-translate="header.byCompanySize">By Company Size</h3>
								<a href={smallBusinessHref} data-localized-path={smallBusinessPath} data-nav-link class="garna-header-dropdown-link">
									<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect>
										<path d="M9 22v-4h6v4"></path>
										<path d="M8 6h.01"></path>
										<path d="M16 6h.01"></path>
										<path d="M12 10h.01"></path>
										<path d="M8 14h.01"></path>
										<path d="M16 14h.01"></path>
									</svg>
									<span class="garna-header-link-main" data-translate="header.smallBusiness">Small Business Payroll</span>
									<span class="garna-header-link-separator">|</span>
									<span class="garna-header-link-kicker" data-translate="header.smallBusinessKicker">For teams under 50 people</span>
								</a>
								<a href={midSizeHref} data-localized-path={midSizePath} data-nav-link class="garna-header-dropdown-link">
									<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path>
										<path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path>
										<path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path>
										<path d="M10 6h4"></path>
										<path d="M10 10h4"></path>
										<path d="M10 14h4"></path>
										<path d="M10 18h4"></path>
									</svg>
									<span class="garna-header-link-main" data-translate="header.midSizeBusiness">Mid-Size Business Payroll</span>
									<span class="garna-header-link-separator">|</span>
									<span class="garna-header-link-kicker" data-translate="header.midSizeBusinessKicker">Growing teams 50-500</span>
								</a>
								<a href={enterprisePayrollHref} data-localized-path={enterprisePayrollPath} data-nav-link class="garna-header-dropdown-link">
									<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<line x1="3" x2="21" y1="22" y2="22"></line>
										<line x1="6" x2="6" y1="18" y2="11"></line>
										<line x1="10" x2="10" y1="18" y2="11"></line>
										<line x1="14" x2="14" y1="18" y2="11"></line>
										<line x1="18" x2="18" y1="18" y2="11"></line>
										<polygon points="12 2 20 7 4 7"></polygon>
									</svg>
									<span class="garna-header-link-main" data-translate="header.enterprise">Enterprise Payroll</span>
									<span class="garna-header-link-separator">|</span>
									<span class="garna-header-link-kicker" data-translate="header.enterpriseKicker">Complex global operations</span>
								</a>
							</div>

							<div class="garna-header-divider"></div>

							<div class="garna-header-dropdown-column">
								<h3 class="garna-header-dropdown-title" data-translate="header.byNeed">By Need</h3>
								<a href={whiteLabelHref} data-localized-path={whiteLabelPath} data-nav-link class="garna-header-dropdown-link">
									<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
										<polyline points="2 12 12 17 22 12"></polyline>
										<polyline points="2 17 12 22 22 17"></polyline>
									</svg>
									<span class="garna-header-link-main" data-translate="header.whiteLabelPayroll">White Label Payroll</span>
									<span class="garna-header-link-separator">|</span>
									<span class="garna-header-link-kicker" data-translate="header.whiteLabelKicker">Embed payroll in your app</span>
								</a>
								<a href={offerHref} data-localized-path="for-contractors" data-nav-link class="garna-header-dropdown-link">
									<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<polyline points="16 11 18 13 22 9"></polyline>
									</svg>
									<span class="garna-header-link-main" data-translate="header.forContractors">For Contractors</span>
									<span class="garna-header-link-separator">|</span>
									<span class="garna-header-link-kicker" data-translate="header.contractorsKicker">Get paid faster globally</span>
								</a>
								<a href={aiHiringHref} data-localized-path="ai-hiring" data-nav-link class="garna-header-dropdown-link">
									<svg class="garna-header-dropdown-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M12 8V4H8"></path>
										<rect width="16" height="12" x="4" y="8" rx="2"></rect>
										<path d="M2 14h2"></path>
										<path d="M20 14h2"></path>
										<path d="M15 13v2"></path>
										<path d="M9 13v2"></path>
									</svg>
									<span class="garna-header-link-main" data-translate="header.aiHiring">AI Hiring</span>
									<span class="garna-header-link-separator">|</span>
									<span class="garna-header-link-kicker" data-translate="header.aiHiringFeatureText">Automate talent sourcing</span>
								</a>
							</div>
						</div>

						<a href={aiHiringHref} data-localized-path="ai-hiring" data-nav-link class="garna-header-dropdown-feature garna-header-solutions-feature" aria-label="AI Hiring">
							<img src="/images/header-ai-hiring.jpg" alt="" loading="lazy" />
							<div class="garna-header-feature-copy">
								<h4 data-translate="header.aiHiring">AI Hiring</h4>
								<p data-translate="header.aiHiringFeatureText">Automate talent sourcing</p>
								<span class="garna-header-feature-link">
									<span data-translate="header.learnMore">Learn more</span>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M5 12h14"></path>
										<path d="m12 5 7 7-7 7"></path>
									</svg>
								</span>
							</div>
						</a>
					</div>
				</div>
			</div>

			<a
				href={blogHref}
				data-localized-path="blog"
				data-nav-link
				class={navLinkClass('blog')}
				data-translate="header.blog"
			>
				Blog
			</a>
		</div>

		<div class="garna-header-actions">
			<Button href={logInUrl} variant="secondary" size="header" class="garna-header-login" data-garna-signin>
				<svg
					class="garna-header-login-icon"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
					<polyline points="10 17 15 12 10 7"></polyline>
					<line x1="15" x2="3" y1="12" y2="12"></line>
				</svg>
				<span data-translate="header.logIn">Log In</span>
			</Button>

			<Button href={signUpUrl} id="header-signup-btn" class="garna-header-signup" data-garna-signup data-translate="header.signUp">
				Sign Up
			</Button>

			<Button
				type="button"
				variant="icon"
				size="icon"
				class="md:hidden"
				aria-label="Toggle Menu"
				aria-controls="mobile-nav-menu"
				aria-expanded="false"
				data-mobile-nav-toggle
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="menu-icon w-6 h-6 lucide lucide-menu"
					aria-hidden="true"
				>
					<line x1="4" x2="20" y1="12" y2="12"></line>
					<line x1="4" x2="20" y1="6" y2="6"></line>
					<line x1="4" x2="20" y1="18" y2="18"></line>
				</svg>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="close-icon hidden w-8 h-8 lucide lucide-x"
					aria-hidden="true"
				>
					<path d="M18 6 6 18"></path>
					<path d="M6 6 18 18"></path>
				</svg>
			</Button>
		</div>

		<div
			id="mobile-nav-menu"
			class="hidden garna-header-mobile-menu"
		>
			<div class="garna-header-mobile-scroll">
				<div class="garna-header-mobile-group">
				<div class="garna-header-mobile-section" data-translate="header.products">Products</div>
				<a href={homeHref} data-localized-path="" data-nav-link data-nav-mobile class={`${mobileLinkClass('')} garna-header-mobile-card`}>
					<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="10"></circle>
						<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
						<path d="M2 12h20"></path>
					</svg>
					<span class="garna-header-mobile-link-main" data-translate="header.globalPayroll">Global Payroll</span>
					<span class="garna-header-mobile-link-kicker" data-translate="header.globalPayrollKicker">Pay teams worldwide</span>
				</a>
				<a
					href={eorHref}
					data-localized-path={employerOfRecordPath}
					data-nav-link
					data-nav-mobile
					class={`${mobileLinkClass(employerOfRecordPath)} garna-header-mobile-card`}
				>
					<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
						<circle cx="9" cy="7" r="4"></circle>
						<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
						<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
					</svg>
					<span class="garna-header-mobile-link-main" data-translate="header.eor">Employer of Record</span>
					<span class="garna-header-mobile-link-kicker" data-translate="header.eorKicker">Hire without local entity</span>
				</a>
				<a
					href={contractorOfRecordHref}
					data-localized-path={contractorOfRecordPath}
					data-nav-link
					data-nav-mobile
					class={`${mobileLinkClass(contractorOfRecordPath)} garna-header-mobile-card`}
				>
					<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
						<path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
					</svg>
					<span class="garna-header-mobile-link-main" data-translate="header.contractorOfRecord">Contractor of Record</span>
					<span class="garna-header-mobile-link-kicker" data-translate="header.contractorOfRecordKicker">Manage global contractors</span>
				</a>
			</div>

			<div class="garna-header-mobile-group">
				<div class="garna-header-mobile-section" data-translate="header.solutions">Solutions</div>
				<div class="garna-header-mobile-subgroup">
					<div class="garna-header-mobile-subsection" data-translate="header.byCompanySize">By Company Size</div>
					<a
						href={smallBusinessHref}
						data-localized-path={smallBusinessPath}
						data-nav-link
						data-nav-mobile
						class={`${mobileLinkClass(smallBusinessPath)} garna-header-mobile-card`}
					>
						<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect>
							<path d="M9 22v-4h6v4"></path>
							<path d="M8 6h.01"></path>
							<path d="M16 6h.01"></path>
							<path d="M12 10h.01"></path>
							<path d="M8 14h.01"></path>
							<path d="M16 14h.01"></path>
						</svg>
						<span class="garna-header-mobile-link-main" data-translate="header.smallBusiness">Small Business Payroll</span>
						<span class="garna-header-mobile-link-kicker" data-translate="header.smallBusinessKicker">For teams under 50 people</span>
					</a>
					<a
						href={midSizeHref}
						data-localized-path={midSizePath}
						data-nav-link
						data-nav-mobile
						class={`${mobileLinkClass(midSizePath)} garna-header-mobile-card`}
					>
						<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path>
							<path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path>
							<path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path>
							<path d="M10 6h4"></path>
							<path d="M10 10h4"></path>
							<path d="M10 14h4"></path>
							<path d="M10 18h4"></path>
						</svg>
						<span class="garna-header-mobile-link-main" data-translate="header.midSizeBusiness">Mid-Size Business Payroll</span>
						<span class="garna-header-mobile-link-kicker" data-translate="header.midSizeBusinessKicker">Growing teams 50-500</span>
					</a>
					<a
						href={enterprisePayrollHref}
						data-localized-path={enterprisePayrollPath}
						data-nav-link
						data-nav-mobile
						class={`${mobileLinkClass(enterprisePayrollPath)} garna-header-mobile-card`}
					>
						<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="3" x2="21" y1="22" y2="22"></line>
							<line x1="6" x2="6" y1="18" y2="11"></line>
							<line x1="10" x2="10" y1="18" y2="11"></line>
							<line x1="14" x2="14" y1="18" y2="11"></line>
							<line x1="18" x2="18" y1="18" y2="11"></line>
							<polygon points="12 2 20 7 4 7"></polygon>
						</svg>
						<span class="garna-header-mobile-link-main" data-translate="header.enterprise">Enterprise Payroll</span>
						<span class="garna-header-mobile-link-kicker" data-translate="header.enterpriseKicker">Complex global operations</span>
					</a>
				</div>
				<div class="garna-header-mobile-subgroup">
					<div class="garna-header-mobile-subsection" data-translate="header.byNeed">By Need</div>
					<a
						href={whiteLabelHref}
						data-localized-path={whiteLabelPath}
						data-nav-link
						data-nav-mobile
						class={`${mobileLinkClass(whiteLabelPath)} garna-header-mobile-card`}
					>
						<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
							<polyline points="2 12 12 17 22 12"></polyline>
							<polyline points="2 17 12 22 22 17"></polyline>
						</svg>
						<span class="garna-header-mobile-link-main" data-translate="header.whiteLabelPayroll">White Label Payroll</span>
						<span class="garna-header-mobile-link-kicker" data-translate="header.whiteLabelKicker">Embed payroll in your app</span>
					</a>
					<a
						href={offerHref}
						data-localized-path="for-contractors"
						data-nav-link
						data-nav-mobile
						class={`${mobileLinkClass('for-contractors')} garna-header-mobile-card`}
					>
						<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
							<circle cx="9" cy="7" r="4"></circle>
							<polyline points="16 11 18 13 22 9"></polyline>
						</svg>
						<span class="garna-header-mobile-link-main" data-translate="header.forContractors">For Contractors</span>
						<span class="garna-header-mobile-link-kicker" data-translate="header.contractorsKicker">Get paid faster globally</span>
					</a>
					<a
						href={aiHiringHref}
						data-localized-path="ai-hiring"
						data-nav-link
						data-nav-mobile
						class={`${mobileLinkClass('ai-hiring')} garna-header-mobile-card`}
					>
						<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 8V4H8"></path>
							<rect width="16" height="12" x="4" y="8" rx="2"></rect>
							<path d="M2 14h2"></path>
							<path d="M20 14h2"></path>
							<path d="M15 13v2"></path>
							<path d="M9 13v2"></path>
						</svg>
						<span class="garna-header-mobile-link-main" data-translate="header.aiHiring">AI Hiring</span>
						<span class="garna-header-mobile-link-kicker" data-translate="header.aiHiringFeatureText">Automate talent sourcing</span>
					</a>
				</div>
			</div>

			<div class="garna-header-mobile-group">
				<div class="garna-header-mobile-section" data-translate="header.resources">Resources</div>
				<a
					href={blogHref}
					data-localized-path="blog"
					data-nav-link
					data-nav-mobile
					class={`${mobileLinkClass('blog')} garna-header-mobile-card`}
				>
					<svg class="garna-header-mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
						<path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"></path>
					</svg>
					<span class="garna-header-mobile-link-main" data-translate="header.blog">Blog</span>
					<span class="garna-header-mobile-link-kicker" data-translate="header.blogKicker">Articles and company updates</span>
				</a>
			</div>
			</div>

			<div class="garna-header-mobile-actions">
				<div class="garna-header-mobile-divider"></div>
				<div class="garna-header-mobile-buttons">
					<Button
						href={logInUrl}
						variant="secondary"
						size="mobile"
						data-garna-signin
						data-translate="header.logIn"
					>
						Log In
					</Button>
					<Button
						href={signUpUrl}
						size="mobile"
						data-garna-signup
						data-translate="header.signUp"
					>
						Sign Up
					</Button>
				</div>
			</div>
		</div>
	</div>
</nav>

<script>
	(() => {
		const toggle = document.querySelector('[data-mobile-nav-toggle]');
		const menu = document.getElementById('mobile-nav-menu');
		const signUpButton = document.getElementById('header-signup-btn');
		const header = document.querySelector('.garna-header');

		const supportedLangs = ['en', 'es', 'pt', 'ru'];

		const getLangFromPath = (pathname = window.location.pathname) => {
			const [firstSegment] = pathname.split('/').filter(Boolean);
			const lang = firstSegment?.toLowerCase();
			return supportedLangs.includes(lang) ? lang : 'en';
		};

		const getCurrentLang = () =>
			getLangFromPath(window.location.pathname)
			|| document.documentElement.lang?.split('-')[0]?.toLowerCase()
			|| 'en';

		const closeMobileMenu = () => {
			if (!toggle || !menu) return;
			toggle.setAttribute('aria-expanded', 'false');
			menu.classList.add('hidden');
			header?.classList.remove('is-mobile-open');
			document.body.classList.remove('overflow-hidden');
			toggle.querySelector('.menu-icon')?.classList.remove('hidden');
			toggle.querySelector('.close-icon')?.classList.add('hidden');
			signUpButton?.classList.remove('hidden');
		};

		const closeHeaderDropdowns = (source) => {
			const group = source instanceof Element ? source.closest('.garna-header-menu-group') : null;
			if (group instanceof HTMLElement) group.classList.add('is-dropdown-suppressed');
			if (document.activeElement instanceof HTMLElement) document.activeElement.blur();
		};

		document.querySelectorAll('.garna-header-menu-group').forEach((group) => {
			group.addEventListener('mouseleave', () => {
				group.classList.remove('is-dropdown-suppressed');
			});
		});

		document.querySelectorAll('.garna-header-menu-trigger').forEach((trigger) => {
			trigger.addEventListener('click', () => {
				if (trigger instanceof HTMLElement) trigger.blur();
			});
		});

		toggle?.addEventListener('click', () => {
			const isOpen = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!isOpen));
			menu?.classList.toggle('hidden');
			header?.classList.toggle('is-mobile-open', !isOpen);
			document.body.classList.toggle('overflow-hidden');
			toggle.querySelector('.menu-icon')?.classList.toggle('hidden');
			toggle.querySelector('.close-icon')?.classList.toggle('hidden');
			signUpButton?.classList.toggle('hidden');
		});

		const localizeHeaderLinks = () => {
			const currentLang = getCurrentLang();
			document.querySelectorAll('[data-localized-path]').forEach((link) => {
				if (!(link instanceof HTMLAnchorElement)) return;
				const path = link.dataset.localizedPath;
				link.href = path ? `/${currentLang}/${path}` : `/${currentLang}`;
			});

			document.querySelectorAll('[data-garna-signup]').forEach((link) => {
				if (link instanceof HTMLAnchorElement) link.href = `https://app.garna.io/${currentLang}/auth/sign-up`;
			});

			document.querySelectorAll('[data-garna-signin]').forEach((link) => {
				if (link instanceof HTMLAnchorElement) link.href = `https://app.garna.io/${currentLang}/auth/sign-in`;
			});
		};

		const normalizePagePath = (path = '') => path.replace(/\/?index\.html$/, '').replace(/\.html$/, '');

		const getPagePath = (pathname = window.location.pathname) => {
			const parts = pathname.split('/').filter(Boolean);
			const pagePath = parts.length > 0 && ['en', 'es', 'pt', 'ru'].includes(parts[0].toLowerCase())
				? parts.slice(1).join('/')
				: parts.join('/');
			return normalizePagePath(pagePath);
		};

		const setNavActiveState = () => {
			const currentPath = getPagePath();
			const setSingleActiveLink = (selector) => {
				let activeAssigned = false;
				document.querySelectorAll(selector).forEach((link) => {
					if (!(link instanceof HTMLElement)) return;
					const linkPath = link.dataset.localizedPath || '';
					const isActive = !activeAssigned && linkPath === currentPath;
					link.classList.toggle('is-active', isActive);
					if (isActive) activeAssigned = true;
				});
			};

			setSingleActiveLink('[data-nav-link]:not([data-nav-mobile])');
			setSingleActiveLink('[data-nav-link][data-nav-mobile]');

		};

		const isScriptRuntimeReady = (src) => {
			if (src.includes('iconify-icon')) return Boolean(window.customElements?.get?.('iconify-icon'));
			if (src.includes('lucide')) return Boolean(window.lucide);
			return false;
		};

		const needsScriptRuntimeCheck = (src) => src.includes('iconify-icon') || src.includes('lucide');

		const loadHeadScript = (sourceScript) => {
			const src = sourceScript.getAttribute('src');
			if (!src) return Promise.resolve();

			const absoluteSrc = new URL(src, window.location.origin).href;
			const existingScript = document.head.querySelector(`script[src="${absoluteSrc}"], script[src="${src}"]`);
			if (existingScript && (!needsScriptRuntimeCheck(absoluteSrc) || isScriptRuntimeReady(absoluteSrc))) return Promise.resolve();

			return new Promise((resolve) => {
				const freshScript = document.createElement('script');
				Array.from(sourceScript.attributes).forEach((attribute) => {
					if (attribute.name === 'is:inline') return;
					freshScript.setAttribute(attribute.name, attribute.value);
				});
				freshScript.src = absoluteSrc;
				freshScript.async = false;
				freshScript.addEventListener('load', resolve, { once: true });
				freshScript.addEventListener('error', resolve, { once: true });
				document.head.appendChild(freshScript);
			});
		};

		const appendMissingHeadResources = async (targetDoc) => {
			const pendingScripts = [];

			targetDoc.querySelectorAll('head script[src], head link[rel="stylesheet"]').forEach((resource) => {
				if (!(resource instanceof HTMLScriptElement) && !(resource instanceof HTMLLinkElement)) return;
				const attr = resource instanceof HTMLScriptElement ? 'src' : 'href';
				const value = resource.getAttribute(attr);
				if (!value) return;
				const absoluteValue = new URL(value, window.location.origin).href;

				if (resource instanceof HTMLScriptElement) {
					const existingScript = document.head.querySelector(`script[src="${absoluteValue}"], script[src="${value}"]`);
					if (!existingScript || (needsScriptRuntimeCheck(absoluteValue) && !isScriptRuntimeReady(absoluteValue))) {
						pendingScripts.push(loadHeadScript(resource));
					}
					return;
				}

				const selector = resource instanceof HTMLScriptElement
					? `script[src="${absoluteValue}"], script[src="${value}"]`
					: `link[rel="stylesheet"][href="${absoluteValue}"], link[rel="stylesheet"][href="${value}"]`;
				if (document.head.querySelector(selector)) return;
				document.head.appendChild(resource.cloneNode(true));
			});

			await Promise.all(pendingScripts);
		};

		const syncHead = async (targetDoc) => {
			document.title = targetDoc.title || document.title;
			document.documentElement.lang = targetDoc.documentElement.lang || document.documentElement.lang;

			const selectors = [
				'meta[name="description"]',
				'meta[property^="og:"]',
				'meta[name^="twitter:"]',
				'link[rel="canonical"]',
				'link[rel="alternate"]',
			];

			selectors.forEach((selector) => {
				document.head.querySelectorAll(selector).forEach((element) => element.remove());
				targetDoc.head.querySelectorAll(selector).forEach((element) => {
					document.head.appendChild(element.cloneNode(true));
				});
			});

			await appendMissingHeadResources(targetDoc);
		};

		const refreshPageIcons = () => {
			if (window.lucide && typeof window.lucide.createIcons === 'function') {
				window.lucide.createIcons();
			}
		};

		const syncFooterDynamicBlocks = (targetDoc) => {
			[
				'.footer-lang-select-block',
				'.footer-legal-links',
			].forEach((selector) => {
				const currentBlock = document.querySelector(selector);
				const targetBlock = targetDoc.querySelector(selector);
				if (currentBlock && targetBlock) currentBlock.replaceWith(targetBlock.cloneNode(true));
			});
		};

		const syncFooterLanguageState = () => {
			const currentLang = getCurrentLang();
			const currentPath = getPagePath();
			document.querySelectorAll('[data-footer-lang-link]').forEach((link) => {
				if (!(link instanceof HTMLAnchorElement)) return;
				const url = new URL(link.href, window.location.href);
				const parts = url.pathname.split('/').filter(Boolean);
				const linkLang = parts[0]?.toLowerCase();
				const linkPath = parts.slice(1).join('/');
				const isCurrent = linkLang === currentLang;

				if (linkPath !== currentPath) {
					link.href = currentPath ? `/${linkLang}/${currentPath}` : `/${linkLang}`;
				}

				link.classList.toggle('footer-lang-optionSelected', isCurrent);
				link.setAttribute('aria-selected', String(isCurrent));
				if (isCurrent) {
					const trigger = document.querySelector('.footer-lang-triggerText');
					if (trigger) trigger.textContent = link.textContent || currentLang;
				}
			});
		};

		const closeFooterLanguageMenus = (except) => {
			document.querySelectorAll('.footer-lang-label.is-open').forEach((container) => {
				if (except && container === except) return;
				container.classList.remove('is-open');
				container.querySelector('[data-footer-lang-trigger]')?.setAttribute('aria-expanded', 'false');
			});
		};

		const resetPageWidget = () => {
			const widget = window.GarnaWidget;
			if (widget && typeof widget.destroy === 'function') widget.destroy();
			document.getElementById('garna-widget-root')?.remove();
		};

		const enableInstantScroll = () => {
			const root = document.documentElement;
			const body = document.body;
			const previous = {
				rootScrollBehavior: root.style.getPropertyValue('scroll-behavior'),
				rootScrollBehaviorPriority: root.style.getPropertyPriority('scroll-behavior'),
				bodyScrollBehavior: body.style.getPropertyValue('scroll-behavior'),
				bodyScrollBehaviorPriority: body.style.getPropertyPriority('scroll-behavior'),
				rootOverflowAnchor: root.style.getPropertyValue('overflow-anchor'),
				bodyOverflowAnchor: body.style.getPropertyValue('overflow-anchor'),
			};

			root.classList.add('garna-instant-scroll');
			root.style.setProperty('scroll-behavior', 'auto', 'important');
			body.style.setProperty('scroll-behavior', 'auto', 'important');
			root.style.setProperty('overflow-anchor', 'none');
			body.style.setProperty('overflow-anchor', 'none');

			return () => {
				root.classList.remove('garna-instant-scroll');

				if (previous.rootScrollBehavior) {
					root.style.setProperty('scroll-behavior', previous.rootScrollBehavior, previous.rootScrollBehaviorPriority);
				} else {
					root.style.removeProperty('scroll-behavior');
				}

				if (previous.bodyScrollBehavior) {
					body.style.setProperty('scroll-behavior', previous.bodyScrollBehavior, previous.bodyScrollBehaviorPriority);
				} else {
					body.style.removeProperty('scroll-behavior');
				}

				if (previous.rootOverflowAnchor) {
					root.style.setProperty('overflow-anchor', previous.rootOverflowAnchor);
				} else {
					root.style.removeProperty('overflow-anchor');
				}

				if (previous.bodyOverflowAnchor) {
					body.style.setProperty('overflow-anchor', previous.bodyOverflowAnchor);
				} else {
					body.style.removeProperty('overflow-anchor');
				}
			};
		};

		const jumpToPageTop = () => {
			window.scrollTo(0, 0);
			document.documentElement.scrollTop = 0;
			document.body.scrollTop = 0;
		};

		const runScripts = async (scope) => {
			const scripts = Array.from(scope.querySelectorAll('script'));
			for (const script of scripts) {
				const freshScript = document.createElement('script');
				Array.from(script.attributes).forEach((attribute) => {
					freshScript.setAttribute(attribute.name, attribute.value);
				});
				freshScript.textContent = script.textContent;
				if (freshScript.src) freshScript.async = false;
				script.replaceWith(freshScript);

				if (freshScript.src) {
					await new Promise((resolve) => {
						freshScript.addEventListener('load', resolve, { once: true });
						freshScript.addEventListener('error', resolve, { once: true });
					});
				}
			}
		};

		const navigate = async (url, shouldPushState = true) => {
			const currentContent = document.getElementById('astro-page-content');
			const currentScripts = document.getElementById('astro-page-scripts');
			if (!currentContent || !currentScripts) {
				window.location.href = url.href;
				return;
			}

			try {
				const fetchUrl = new URL(url.href);
				fetchUrl.searchParams.set('__garna_spa', String(Date.now()));

				const response = await fetch(fetchUrl.href, {
					cache: 'no-store',
					headers: {
						'X-Requested-With': 'astro-spa-navigation',
						'Cache-Control': 'no-cache',
						'Pragma': 'no-cache',
					},
				});
				if (!response.ok) throw new Error(`Navigation failed with ${response.status}`);

				const html = await response.text();
				const targetDoc = new DOMParser().parseFromString(html, 'text/html');
				const targetContent = targetDoc.getElementById('astro-page-content');
				const targetScripts = targetDoc.getElementById('astro-page-scripts');
				if (!targetContent || !targetScripts) throw new Error('Target page is missing SPA containers');

				const restoreScroll = enableInstantScroll();
				jumpToPageTop();
				try {
					if (shouldPushState) history.pushState({}, '', url.href);
					await syncHead(targetDoc);
					localizeHeaderLinks();
					setNavActiveState();
					syncFooterDynamicBlocks(targetDoc);
					resetPageWidget();

					jumpToPageTop();
					currentContent.replaceWith(targetContent);
					currentScripts.replaceWith(targetScripts);
					jumpToPageTop();
					await runScripts(targetContent);
					await runScripts(targetScripts);
					refreshPageIcons();
					jumpToPageTop();
					window.dispatchEvent(new CustomEvent('garna:page-content-updated'));
					jumpToPageTop();

					requestAnimationFrame(() => {
						jumpToPageTop();
						requestAnimationFrame(() => {
							jumpToPageTop();
							restoreScroll();
						});
					});
				} catch (error) {
					restoreScroll();
					throw error;
				}

				localizeHeaderLinks();
				setNavActiveState();
				syncFooterLanguageState();
				closeMobileMenu();
			} catch (error) {
				console.warn('[garna navigation] Falling back to full page load:', error);
				window.location.href = url.href;
			}
		};

		document.addEventListener('click', (event) => {
			const target = event.target instanceof Element ? event.target : null;
			const trigger = target?.closest('[data-footer-lang-trigger]');
			if (trigger instanceof HTMLElement) {
				const container = trigger.closest('.footer-lang-label');
				if (container instanceof HTMLElement) {
					const willOpen = !container.classList.contains('is-open');
					closeFooterLanguageMenus(container);
					container.classList.toggle('is-open', willOpen);
					trigger.setAttribute('aria-expanded', String(willOpen));
				}
				return;
			}

			if (target?.closest('[data-footer-lang-link]')) {
				closeFooterLanguageMenus();
			} else if (!target?.closest('.footer-lang-label')) {
				closeFooterLanguageMenus();
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') closeFooterLanguageMenus();
		});

		document.addEventListener('click', (event) => {
			if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
			const link = event.target instanceof Element
				? event.target.closest('a[data-localized-path]')
				: null;
			if (!(link instanceof HTMLAnchorElement)) return;

			if (link.closest('.garna-header-dropdown')) closeHeaderDropdowns(link);
			closeMobileMenu();
		});

		if ('scrollRestoration' in history) {
			history.scrollRestoration = 'manual';
		}

		localizeHeaderLinks();
		setNavActiveState();
		syncFooterLanguageState();
	})();
</script>
